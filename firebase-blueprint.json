{
  "entities": {
    "Audio": {
      "title": "Audio Track",
      "description": "An audio segment with transcript and illustration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "titulo": { "type": "string" },
        "texto": { "type": "string" },
        "illustration": { "type": "string" }
      },
      "required": ["id", "titulo", "texto"]
    },
    "Lesson": {
      "title": "Lesson Module",
      "description": "A module containing multiple audio tracks.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nomeDaAula": { "type": "string" },
        "audios": {
          "type": "array",
          "items": { "type": "object", "properties": {
            "id": { "type": "string" },
            "titulo": { "type": "string" },
            "texto": { "type": "string" },
            "illustration": { "type": "string" }
          }}
        },
        "order": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nomeDaAula", "audios"]
    }
  },
  "firestore": {
    "/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Collection of lesson modules."
    }
  }
}
